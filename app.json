{
  "expo": {
    "name": "RAHVerse",
    "slug": "Mobileproject",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobileproject",
    "backgroundColor": "#0f172a",
    "userInterfaceStyle": "automatic",
    "ios": {
      "backgroundColor": "#0f172a",
      "supportsTablet": true
    },
    "android": {
      "backgroundColor": "#0f172a",
      "adaptiveIcon": {
        "backgroundColor": "#0f172a",
        "foregroundImage": "./assets/images/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.myhanni.Mobileproject"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0f172a",
          "dark": {
            "backgroundColor": "#0f172a"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-calendar",
        {
          "calendarPermission": "Aplikasi ini membutuhkan akses kalender untuk menyimpan pengingat agenda."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a57fe8e9-3540-46ec-be06-1a704fd79191"
      }
    }
  }
}
